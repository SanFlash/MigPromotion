
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MIG Staffing – LinkedIn Promo</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ══════════════════════════════════════════════════════
   EDITABLE CONFIG is in the <script> block at bottom
   Search for: ╔══ EDIT HERE ══╗
══════════════════════════════════════════════════════ */

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --bg:       #04080f;
  --surface:  #0b1220;
  --panel:    #0d1728;
  --gold:     #e8a020;
  --gold2:    #ffd060;
  --blue:     #1565ff;
  --cyan:     #00d4ff;
  --white:    #f0f4ff;
  --muted:    #7a8aaa;
  --border:   rgba(255,255,255,.07);
  --sz:       560px;
}

html,body{
  width:100%;height:100%;
  background:#111;
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Sans',sans-serif;
  overflow:hidden;
}

/* ── FRAME (square) ── */
#frame{
  position:relative;
  width:var(--sz);height:var(--sz);
  background:var(--bg);
  overflow:hidden;
  border-radius:4px;
  box-shadow:0 0 80px rgba(0,0,0,.8);
  flex-shrink:0;
}

/* ── CANVAS LAYERS ── */
#cvBg,#cvLines{
  position:absolute;inset:0;
  width:100%;height:100%;
  pointer-events:none;z-index:0;
}
#cvLines{z-index:1;}

/* ── NOISE OVERLAY ── */
#frame::after{
  content:'';
  position:absolute;inset:0;z-index:2;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
  opacity:.025;
  pointer-events:none;
}

/* ── DIAGONAL ACCENT STRIPE ── */
.diag{
  position:absolute;
  width:4px;height:200%;
  background:linear-gradient(180deg,transparent,var(--gold),transparent);
  opacity:.08;
  transform:rotate(25deg);
  pointer-events:none;z-index:1;
}

/* ══ SCENES ══ */
.scene{
  position:absolute;inset:0;
  z-index:10;
  display:none;
  opacity:0;
}
.scene.active{display:flex;}

/* ══════════════════════════════
   SCENE 1 — OPENING SPLIT
══════════════════════════════ */
#s1{flex-direction:column;align-items:center;justify-content:center;}

.s1-eyebrow{
  font-family:'DM Sans',sans-serif;
  font-size:11px;font-weight:600;letter-spacing:6px;
  text-transform:uppercase;
  color:var(--gold);
  opacity:0;transform:translateY(16px);
  transition:opacity .5s,transform .5s;
}
.s1-headline{
  font-family:'Syne',sans-serif;
  font-size:52px;font-weight:800;
  color:var(--white);
  line-height:1.0;
  text-align:center;
  margin-top:12px;
  opacity:0;transform:translateY(24px);
  transition:opacity .6s .12s,transform .6s .12s;
}
.s1-headline em{
  font-style:normal;
  background:linear-gradient(90deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.s1-sub{
  font-size:14px;font-weight:400;
  color:var(--muted);letter-spacing:2px;
  text-transform:uppercase;margin-top:14px;
  opacity:0;transform:translateY(12px);
  transition:opacity .5s .25s,transform .5s .25s;
}
.s1-bar{
  width:0;height:2px;margin-top:20px;
  background:linear-gradient(90deg,var(--blue),var(--cyan),var(--gold));
  border-radius:2px;
  transition:width .9s .4s cubic-bezier(.77,0,.18,1);
}
.s1-roles-preview{
  display:flex;gap:8px;margin-top:28px;flex-wrap:wrap;justify-content:center;
  opacity:0;transform:translateY(10px);
  transition:opacity .5s .5s,transform .5s .5s;
}
.s1-chip{
  padding:5px 12px;border-radius:20px;
  font-size:10px;font-weight:600;letter-spacing:1px;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.1);
  color:var(--muted);
  text-transform:uppercase;
}
#s1.active .s1-eyebrow{opacity:1;transform:translateY(0);}
#s1.active .s1-headline{opacity:1;transform:translateY(0);}
#s1.active .s1-sub{opacity:1;transform:translateY(0);}
#s1.active .s1-bar{width:220px;}
#s1.active .s1-roles-preview{opacity:1;transform:translateY(0);}

/* ══════════════════════════════
   SCENE 2 — ROLES WALL
══════════════════════════════ */
#s2{flex-direction:column;align-items:center;justify-content:center;gap:0;}

.s2-title{
  font-family:'Syne',sans-serif;
  font-size:13px;font-weight:700;letter-spacing:5px;
  text-transform:uppercase;color:var(--cyan);
  margin-bottom:18px;
  opacity:0;transform:translateY(-10px);
  transition:opacity .4s,transform .4s;
}
#s2.active .s2-title{opacity:1;transform:translateY(0);}

#roles-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:8px;
  width:440px;
}
.rcard{
  display:flex;align-items:center;gap:12px;
  padding:11px 14px;
  background:rgba(255,255,255,.04);
  border:1px solid var(--border);
  border-radius:10px;
  opacity:0;
  transform:translateX(-40px);
  transition:opacity .4s,transform .4s,border-color .3s,background .3s;
}
.rcard.from-right{transform:translateX(40px);}
.rcard.visible{opacity:1;transform:translateX(0);}
.rcard:hover{background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.18);}

.rcard-icon{
  width:34px;height:34px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;flex-shrink:0;
}
.rcard-text{}
.rcard-name{font-size:12px;font-weight:600;color:var(--white);line-height:1.2;}
.rcard-sub{font-size:10px;color:var(--muted);margin-top:1px;letter-spacing:.5px;}

/* ══════════════════════════════
   SCENE 3 — STACK / FOCUS
══════════════════════════════ */
#s3{align-items:center;justify-content:center;}
#stack-container{
  position:relative;
  width:360px;height:80px;
  perspective:600px;
}
.scard{
  position:absolute;
  left:0;right:0;
  height:70px;
  background:linear-gradient(135deg,#0e1a2e,#1a2a45);
  border:1px solid rgba(255,255,255,.12);
  border-radius:12px;
  display:flex;align-items:center;gap:14px;
  padding:0 18px;
  opacity:0;
  transition:all .6s cubic-bezier(.23,1,.32,1);
}
.scard-icon{
  width:38px;height:38px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;flex-shrink:0;
}
.scard-name{font-size:13px;font-weight:600;color:var(--white);}
.scard-sub{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-top:2px;}

/* ══════════════════════════════
   SCENE 4 — BRAND REVEAL
══════════════════════════════ */
#s4{flex-direction:column;align-items:center;justify-content:center;}

.brand-bg-ring{
  position:absolute;
  border-radius:50%;
  border:1px solid;
  opacity:0;
  transform:scale(0);
  transition:transform 1s cubic-bezier(.23,1,.32,1),opacity .6s;
}
.ring1{width:240px;height:240px;border-color:rgba(232,160,32,.15);transition-delay:.0s;}
.ring2{width:380px;height:380px;border-color:rgba(0,212,255,.1);transition-delay:.1s;}
.ring3{width:520px;height:520px;border-color:rgba(21,101,255,.08);transition-delay:.2s;}

.brand-logo-wrap{
  display:flex;flex-direction:column;align-items:center;
  position:relative;z-index:2;
}
.brand-m{
  font-family:'Syne',sans-serif;
  font-size:90px;font-weight:800;
  line-height:.9;
  background:linear-gradient(140deg,#fff 20%,var(--gold) 60%,var(--gold2) 100%);
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  opacity:0;transform:scale(.4) translateY(20px);
  transition:opacity .5s .1s,transform .6s .1s cubic-bezier(.175,.885,.32,1.275);
}
.brand-full{
  font-family:'Syne',sans-serif;
  font-size:17px;font-weight:700;
  letter-spacing:14px;color:var(--white);
  text-transform:uppercase;
  opacity:0;transform:translateY(10px);
  transition:opacity .5s .35s,transform .5s .35s;
}
.brand-tagline{
  font-size:11px;color:var(--muted);
  letter-spacing:4px;text-transform:uppercase;
  margin-top:8px;
  opacity:0;transform:translateY(8px);
  transition:opacity .5s .5s,transform .5s .5s;
}
.brand-divider{
  width:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--gold),transparent);
  margin-top:14px;
  transition:width .8s .4s;
}
#s4.active .ring1,
#s4.active .ring2,
#s4.active .ring3{opacity:1;transform:scale(1);}
#s4.active .brand-m{opacity:1;transform:scale(1) translateY(0);}
#s4.active .brand-full{opacity:1;transform:translateY(0);}
#s4.active .brand-tagline{opacity:1;transform:translateY(0);}
#s4.active .brand-divider{width:200px;}

/* ══════════════════════════════
   SCENE 5 — CTA
══════════════════════════════ */
#s5{flex-direction:column;align-items:center;justify-content:center;padding:0 40px;}

.cta-tag{
  font-size:10px;font-weight:700;letter-spacing:6px;
  text-transform:uppercase;color:var(--cyan);
  padding:5px 14px;border:1px solid rgba(0,212,255,.3);
  border-radius:20px;background:rgba(0,212,255,.06);
  opacity:0;transform:scale(.8);
  transition:opacity .4s,transform .4s;
}
.cta-headline{
  font-family:'Syne',sans-serif;
  font-size:36px;font-weight:800;
  color:var(--white);text-align:center;
  line-height:1.1;margin-top:18px;
  opacity:0;transform:translateY(20px);
  transition:opacity .5s .1s,transform .5s .1s;
}
.cta-headline span{
  background:linear-gradient(90deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
}
.cta-sub{
  font-size:13px;color:var(--muted);text-align:center;
  margin-top:12px;line-height:1.5;
  opacity:0;transform:translateY(12px);
  transition:opacity .5s .2s,transform .5s .2s;
}

.cta-contact-box{
  margin-top:22px;
  display:flex;flex-direction:column;gap:8px;align-items:center;
  opacity:0;transform:translateY(14px);
  transition:opacity .5s .35s,transform .5s .35s;
}
.contact-row{
  display:flex;align-items:center;gap:10px;
  padding:10px 18px;border-radius:8px;
  background:rgba(255,255,255,.04);
  border:1px solid var(--border);
  width:100%;
}
.contact-icon{
  width:28px;height:28px;border-radius:6px;
  display:flex;align-items:center;justify-content:center;font-size:13px;
  flex-shrink:0;
}
.contact-label{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;}
.contact-value{font-size:12px;font-weight:600;color:var(--white);}

.cta-brand-footer{
  margin-top:20px;
  font-family:'Syne',sans-serif;
  font-size:20px;font-weight:800;letter-spacing:5px;
  background:linear-gradient(90deg,var(--gold),var(--gold2));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;
  background-clip:text;
  opacity:0;transform:scale(.9);
  transition:opacity .5s .5s,transform .5s .5s;
}

#s5.active .cta-tag{opacity:1;transform:scale(1);}
#s5.active .cta-headline{opacity:1;transform:translateY(0);}
#s5.active .cta-sub{opacity:1;transform:translateY(0);}
#s5.active .cta-contact-box{opacity:1;transform:translateY(0);}
#s5.active .cta-brand-footer{opacity:1;transform:scale(1);}

/* ── WIPE TRANSITION ── */
#wipe{
  position:absolute;inset:0;z-index:50;
  background:linear-gradient(135deg,var(--gold) 0%,var(--blue) 100%);
  transform:translateX(-110%);
  pointer-events:none;
}

/* ── PROGRESS ── */
#prog{
  position:absolute;bottom:0;left:0;height:2px;z-index:60;
  background:linear-gradient(90deg,var(--blue),var(--cyan),var(--gold));
  width:0%;
}

/* ── SCENE LABEL ── */
#scene-label{
  position:absolute;top:14px;right:14px;z-index:55;
  font-size:9px;letter-spacing:3px;text-transform:uppercase;
  color:rgba(255,255,255,.25);font-weight:600;
}

/* ── REPLAY ── */
#replay{
  position:absolute;bottom:16px;right:14px;z-index:60;
  padding:7px 16px;border-radius:20px;
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
  color:rgba(255,255,255,.7);font-size:10px;font-weight:600;letter-spacing:2px;
  text-transform:uppercase;cursor:pointer;
  opacity:0;pointer-events:none;transition:opacity .4s,background .2s;
}
#replay:hover{background:rgba(255,255,255,.15);}
#replay.show{opacity:1;pointer-events:all;}

/* ── CORNER MARKS ── */
.corner{position:absolute;width:16px;height:16px;z-index:3;}
.corner.tl{top:12px;left:12px;border-top:2px solid rgba(232,160,32,.5);border-left:2px solid rgba(232,160,32,.5);}
.corner.tr{top:12px;right:12px;border-top:2px solid rgba(232,160,32,.5);border-right:2px solid rgba(232,160,32,.5);}
.corner.bl{bottom:12px;left:12px;border-bottom:2px solid rgba(232,160,32,.5);border-left:2px solid rgba(232,160,32,.5);}
.corner.br{bottom:12px;right:12px;border-bottom:2px solid rgba(232,160,32,.5);border-right:2px solid rgba(232,160,32,.5);}

</style>
</head>
<body>
<div id="frame">
  <!-- bg canvas -->
  <canvas id="cvBg"></canvas>
  <canvas id="cvLines"></canvas>

  <!-- atmosphere -->
  <div class="diag" style="left:15%"></div>
  <div class="diag" style="left:40%"></div>
  <div class="diag" style="left:70%"></div>

  <!-- corners -->
  <div class="corner tl"></div><div class="corner tr"></div>
  <div class="corner bl"></div><div class="corner br"></div>

  <!-- Scene 1 -->
  <div class="scene" id="s1">
    <div class="s1-eyebrow" id="s1-eyebrow"></div>
    <div class="s1-headline" id="s1-headline"></div>
    <div class="s1-sub" id="s1-sub"></div>
    <div class="s1-bar" id="s1-bar"></div>
    <div class="s1-roles-preview" id="s1-chips"></div>
  </div>

  <!-- Scene 2 -->
  <div class="scene" id="s2">
    <div class="s2-title" id="s2-title"></div>
    <div id="roles-grid"></div>
  </div>

  <!-- Scene 3 -->
  <div class="scene" id="s3">
    <div id="stack-container"></div>
  </div>

  <!-- Scene 4 -->
  <div class="scene" id="s4">
    <div class="brand-bg-ring ring1"></div>
    <div class="brand-bg-ring ring2"></div>
    <div class="brand-bg-ring ring3"></div>
    <div class="brand-logo-wrap">
      <div class="brand-m" id="brand-initials"></div>
      <div class="brand-full" id="brand-name"></div>
      <div class="brand-divider"></div>
      <div class="brand-tagline" id="brand-tagline"></div>
    </div>
  </div>

  <!-- Scene 5 -->
  <div class="scene" id="s5">
    <div class="cta-tag" id="cta-tag"></div>
    <div class="cta-headline" id="cta-headline"></div>
    <div class="cta-sub" id="cta-sub"></div>
    <div class="cta-contact-box" id="cta-contacts"></div>
    <div class="cta-brand-footer" id="cta-footer"></div>
  </div>

  <!-- wipe -->
  <div id="wipe"></div>

  <!-- ui -->
  <div id="prog"></div>
  <div id="scene-label"></div>
  <button id="replay">↺ Replay</button>
</div>

<script>
/* ╔══════════════════════════════════════════════════════════╗
   ║              ✏️  EDITABLE CONFIGURATION                  ║
   ╚══════════════════════════════════════════════════════════╝ */

const CONFIG = {

  /* ── Brand ──────────────────────────────────────── */
  brand: {
    initials:   "MIG",                    // large letter shown in reveal
    name:       "MIG STAFFING",           // full company name
    tagline:    "Your Career. Our Mission.",
  },

  /* ── Scene 1: Opening ───────────────────────────── */
  opening: {
    eyebrow:    "We're Hiring",
    headline:   `Looking for\n<em>Opportunities?</em>`,   // <em> = gold
    sub:        "Junior · Mid · Senior Roles",
    chipCount:  4,  // how many role chips to show in preview (taken from roles array)
  },

  /* ── Scene 2: Title ─────────────────────────────── */
  rolesSection: {
    title:      "Open Positions",
  },

  /* ── Scene 5: CTA ───────────────────────────────── */
  cta: {
    tag:        "Join Us Today",
    headline:   `Get Your Dream Job\nwith <span>MIG STAFFING</span>`,
    sub:        "Connect with top companies across the globe.\nLand the role you deserve.",
    footerText: "MIG STAFFING",
  },

  /* ── Contact rows (add / remove freely) ────────── */
  contacts: [
    { icon: "✉️",  label: "Email",    value: "recruitment_offshore@migstaffing.com",  color: "#1565ff" },
    { icon: "💼",  label: "LinkedIn", value: "Follow us for better opportunities",    color: "#0a66c2" },
  ],

  /* ── Roles (add / remove / edit freely) ─────────── */
  roles: [
    { name: "Python Developer",      sub: "Backend Engineering",   icon: "🐍", color: "#3572A5" },
    { name: "Java Developer",        sub: "Enterprise Backend",    icon: "☕", color: "#b07219" },
    { name: "Data Engineer",         sub: "Data Infrastructure",   icon: "📊", color: "#00c6ff" },
    { name: "Full Stack Developer",  sub: "End-to-End Dev",        icon: "⚡", color: "#f5a623" },
    { name: "Data Analyst",          sub: "Analytics & Insights",  icon: "📈", color: "#2ecc71" },
    { name: "Business Analyst",      sub: "Strategy & Process",    icon: "💼", color: "#9b59b6" },
    { name: "QA Engineer",           sub: "Quality Assurance",     icon: "🛡️", color: "#e74c3c" },
    { name: "ETL Tester",            sub: "Data Pipeline Testing", icon: "🔄", color: "#1abc9c" },
    { name: "Automation Engineer",   sub: "Test Automation",       icon: "🤖", color: "#3498db" },
  ],

  /* ── Timing (milliseconds) ──────────────────────── */
  timing: {
    s1Duration:     5500,   // opening hold
    s2Duration:     7000,   // roles wall hold
    s3Duration:     3200,   // stack focus hold
    s4Duration:     5000,   // brand reveal hold
    s5Duration:     6000,   // CTA hold
    wipeSpeed:      420,    // wipe transition ms
  },

};

/* ════════════════════════════════════════════
   END EDITABLE CONFIG — don't touch below
════════════════════════════════════════════ */

/* ── populate DOM ── */
document.getElementById('s1-eyebrow').textContent  = CONFIG.opening.eyebrow;
document.getElementById('s1-headline').innerHTML   = CONFIG.opening.headline.replace(/\n/g,'<br>');
document.getElementById('s1-sub').textContent      = CONFIG.opening.sub;
document.getElementById('s2-title').textContent    = CONFIG.rolesSection.title;
document.getElementById('brand-initials').textContent = CONFIG.brand.initials;
document.getElementById('brand-name').textContent  = CONFIG.brand.name;
document.getElementById('brand-tagline').textContent  = CONFIG.brand.tagline;
document.getElementById('cta-tag').textContent     = CONFIG.cta.tag;
document.getElementById('cta-headline').innerHTML  = CONFIG.cta.headline.replace(/\n/g,'<br>');
document.getElementById('cta-sub').innerHTML       = CONFIG.cta.sub.replace(/\n/g,'<br>');
document.getElementById('cta-footer').textContent  = CONFIG.cta.footerText;

/* chips */
const chipsEl = document.getElementById('s1-chips');
CONFIG.roles.slice(0, CONFIG.opening.chipCount).forEach(r => {
  const c = document.createElement('div');
  c.className = 's1-chip'; c.textContent = r.name.split(' ')[0];
  chipsEl.appendChild(c);
});

/* roles grid */
const grid = document.getElementById('roles-grid');
CONFIG.roles.forEach((r, i) => {
  const d = document.createElement('div');
  d.className = 'rcard' + (i % 2 === 1 ? ' from-right' : '');
  d.innerHTML = `
    <div class="rcard-icon" style="background:${r.color}1a;border:1px solid ${r.color}44">${r.icon}</div>
    <div class="rcard-text">
      <div class="rcard-name">${r.name}</div>
      <div class="rcard-sub">${r.sub}</div>
    </div>`;
  grid.appendChild(d);
});

/* stack cards */
const stackEl = document.getElementById('stack-container');
CONFIG.roles.forEach((r, i) => {
  const d = document.createElement('div');
  d.className = 'scard';
  d.innerHTML = `
    <div class="scard-icon" style="background:${r.color}22;border:1px solid ${r.color}55">${r.icon}</div>
    <div><div class="scard-name">${r.name}</div><div class="scard-sub">${r.sub}</div></div>`;
  stackEl.appendChild(d);
});

/* contacts */
const contactsEl = document.getElementById('cta-contacts');
CONFIG.contacts.forEach(c => {
  const row = document.createElement('div');
  row.className = 'contact-row';
  row.innerHTML = `
    <div class="contact-icon" style="background:${c.color}22;border:1px solid ${c.color}44">${c.icon}</div>
    <div>
      <div class="contact-label">${c.label}</div>
      <div class="contact-value">${c.value}</div>
    </div>`;
